# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=contento
POSTGRES_PASSWORD=contento
POSTGRES_DB=contento

# Connection URL used by services inside Docker (hostname = service name)
DATABASE_URL=postgresql://contento:contento@postgres:5432/contento
# For local dev (outside Docker): DATABASE_URL=postgresql://contento:contento@localhost:5432/contento

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Kafka ─────────────────────────────────────────────────────────────────────
# Internal Docker broker (used by services inside Docker)
KAFKA_BROKERS=kafka:9092
# External listener (for CLI / testing from host): KAFKA_BROKERS=localhost:9094
KAFKA_SCHEMA_REGISTRY_URL=http://karapace:8081

# ── MinIO / S3 ────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=contento
MINIO_ROOT_PASSWORD=contento123
# Internal endpoint (used by services inside Docker)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY_ID=contento
S3_SECRET_ACCESS_KEY=contento123
S3_BUCKET=contento-media

# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_URL=http://clickhouse:8123

# Auth — secret used to sign/verify the email+password JWT (use a long random value, e.g. `openssl rand -hex 32`)
JWT_SECRET=

# ── AI ────────────────────────────────────────────────────────────────────────
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Higgsfield Cloud (video generation) ───────────────────────────────────────
# Get from https://cloud.higgsfield.ai → API Keys  (Key ID + Secret shown separately)
HF_KEY_ID=
HF_KEY=
# Soul ID: UUID returned after POST /v1/custom-references (one-time character training)
HIGGSFIELD_SOUL_ID=
# Video generation quality overrides (optional)
# Speak (talking avatar) quality: mid | high. Default: high
HIGGSFIELD_SPEAK_QUALITY=
# Image-to-video model for silent shots: dop-lite | dop-turbo | dop-standard. Default: dop-standard
HIGGSFIELD_DOP_MODEL=
# Optional: set to 1 to run the full video pipeline with placeholder clips (no credits used)
HIGGSFIELD_MOCK=

# ── Video stitching ───────────────────────────────────────────────────────────
# Final assembly engine: remotion (1080x1920, burned-in word subtitles, branded
# CTA card; default) | ffmpeg (legacy concat fallback). Remotion needs Chromium.
VIDEO_STITCHER=

# ── ElevenLabs (TTS for talking-avatar lip-sync) ──────────────────────────────
# Get from https://elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=
# Voice ID: copy from ElevenLabs dashboard → Voices
ELEVENLABS_VOICE_ID=

# ── Web ───────────────────────────────────────────────────────────────────────
# URL the browser uses to reach the API (reachable from the host machine)
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Instagram sales-funnel agent (feature B2, profile: inbox) ──────────────────
# Meta app id (Facebook Login + Instagram) — OAuth connect of the IG account (api).
FB_APP_ID=
# OAuth redirect URI registered in the Meta app — set to https://<API_DOMAIN>/oauth/meta/callback
FB_REDIRECT_URI=
# Meta app secret — verifies the X-Hub-Signature-256 on the Instagram messaging webhook (api).
FB_APP_SECRET=
# Instagram App ID / Secret — the NEW "Instagram API with Instagram Login" flow (app → Instagram
# product → API setup with Instagram Login). DISTINCT from FB_APP_ID/SECRET. Used for the OAuth
# connect of the IG account (api.instagram.com). Redirect URI is FB_REDIRECT_URI.
IG_APP_ID=
IG_APP_SECRET=
# Verify token you choose; must match the "Verify Token" set in the Meta webhook config (api).
META_WEBHOOK_VERIFY_TOKEN=
# Telegram bot token (from @BotFather) used to deliver lead cards to the sales chat.
TELEGRAM_BOT_TOKEN=
# Telegram chat id of the sales team (fallback if no SALES_TELEGRAM Integration row exists).
SALES_TELEGRAM_CHAT_ID=
# Base URL of the web app — used to build lead-card links in the Telegram handoff.
# In production set to your HTTPS domain, e.g. https://<WEB_DOMAIN>
WEB_BASE_URL=

# ── Edge / HTTPS reverse proxy (Caddy, profile: proxy) ─────────────────────────
# Public hostnames (DNS A-records → this VPS). Caddy auto-provisions Let's Encrypt TLS for
# both: WEB serves the app, API serves the backend + the Instagram webhook.
#   docker compose -f infra/docker-compose.yml --profile proxy up -d caddy
WEB_DOMAIN=
API_DOMAIN=
# Optional: email for Let's Encrypt expiry notices (add a `{ email {$ACME_EMAIL} }` block to Caddyfile).
ACME_EMAIL=
# After setting domains, also update (and rebuild web for NEXT_PUBLIC_API_URL):
#   NEXT_PUBLIC_API_URL=https://<API_DOMAIN>   WEB_BASE_URL=https://<WEB_DOMAIN>
#   FB_REDIRECT_URI=https://<API_DOMAIN>/oauth/meta/callback

# ── Virlo (viral Instagram Reels discovery) ───────────────────────────────────
# Get from https://virlo.ai/developers — silently skipped if unset
VIRLO_API_KEY=

# ── Optional workers (activate with --profile) ────────────────────────────────
WORKSPACE_IDS=
YOUTUBE_API_KEY=        # YouTube Data API v3 key — YouTube fetcher silently skips if unset
YOUTUBE_REGION_CODE=US
GOOGLE_TRENDS_GEO=US
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_SUBREDDIT=technology
RSS_FEED_URLS=
BRAND_NAME=Contento
MENTION_RSS_URLS=
MENTION_POLL_INTERVAL_MIN=15
SCRAPE_INTERVAL_MIN=30
LORA_MOCK_TRAINING=true
