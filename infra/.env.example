# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=contento
POSTGRES_PASSWORD=contento
POSTGRES_DB=contento

# Connection URL used by services inside Docker (hostname = service name)
DATABASE_URL=postgresql://contento:contento@postgres:5432/contento
# For local dev (outside Docker): DATABASE_URL=postgresql://contento:contento@localhost:5432/contento

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Kafka ─────────────────────────────────────────────────────────────────────
# Internal Docker broker (used by services inside Docker)
KAFKA_BROKERS=kafka:9092
# External listener (for CLI / testing from host): KAFKA_BROKERS=localhost:9094
KAFKA_SCHEMA_REGISTRY_URL=http://karapace:8081

# ── MinIO / S3 ────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=contento
MINIO_ROOT_PASSWORD=contento123
# Internal endpoint (used by services inside Docker)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY_ID=contento
S3_SECRET_ACCESS_KEY=contento123
S3_BUCKET=contento-media

# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_URL=http://clickhouse:8123

# ── Auth (Clerk) ──────────────────────────────────────────────────────────────
# Get from https://dashboard.clerk.com
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# ── AI ────────────────────────────────────────────────────────────────────────
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Higgsfield Cloud (video generation) ───────────────────────────────────────
# Get from https://cloud.higgsfield.ai → API Keys  (Key ID + Secret shown separately)
HF_KEY_ID=
HF_KEY=
# Soul ID: UUID returned after POST /v1/custom-references (one-time character training)
HIGGSFIELD_SOUL_ID=
# Optional: set to 1 to run the full video pipeline with placeholder clips (no credits used)
HIGGSFIELD_MOCK=

# ── ElevenLabs (TTS for talking-avatar lip-sync) ──────────────────────────────
# Get from https://elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=
# Voice ID: copy from ElevenLabs dashboard → Voices
ELEVENLABS_VOICE_ID=

# ── Web ───────────────────────────────────────────────────────────────────────
# URL the browser uses to reach the API (reachable from the host machine)
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Virlo (viral Instagram Reels discovery) ───────────────────────────────────
# Get from https://virlo.ai/developers — silently skipped if unset
VIRLO_API_KEY=

# ── Optional workers (activate with --profile) ────────────────────────────────
WORKSPACE_IDS=
YOUTUBE_API_KEY=        # YouTube Data API v3 key — YouTube fetcher silently skips if unset
YOUTUBE_REGION_CODE=US
GOOGLE_TRENDS_GEO=US
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_SUBREDDIT=technology
RSS_FEED_URLS=
BRAND_NAME=Contento
MENTION_RSS_URLS=
MENTION_POLL_INTERVAL_MIN=15
SCRAPE_INTERVAL_MIN=30
LORA_MOCK_TRAINING=true
